// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Lead {
  id        String   @id @default(uuid())
  name      String
  email     String
  message   String
  industry  String?
  leadScore String?
  createdAt DateTime @default(now())
}
